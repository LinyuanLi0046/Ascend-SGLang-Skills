{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "graph_review_result",
  "type": "object",
  "required": [
    "status",
    "review_outcome",
    "reviewed_mapping_granularity",
    "review_summary",
    "knowledge_reference_check",
    "rules_conformance_check",
    "repo_file_evidence_check",
    "path_reconstruction",
    "span_alignment",
    "artifact_promotion"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["partial", "passed"]
    },
    "review_outcome": {
      "type": "string",
      "enum": ["approved", "blocked"]
    },
    "reviewed_mapping_granularity": {
      "type": "string",
      "minLength": 1
    },
    "review_summary": {
      "type": "string",
      "minLength": 1
    },
    "blocking_issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "knowledge_reference_check": {
      "type": "object"
    },
    "rules_conformance_check": {
      "type": "object"
    },
    "repo_file_evidence_check": {
      "$ref": "#/definitions/repoFileEvidenceCheck"
    },
    "path_reconstruction": {
      "type": "object",
      "properties": {
        "sequence_evidence_summary": {
          "type": "object"
        },
        "distinctive_kernel_anchors": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "pattern_segments": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": true
    },
    "decision_templates": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/decisionTemplate"
      }
    },
    "unresolved_template_summary": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/templateSummaryRow"
      }
    },
    "resolved_template_summary": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/templateSummaryRow"
      }
    },
    "remaining_candidates_summary": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/remainingCandidateSummaryRow"
      }
    },
    "elimination_attempts": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/eliminationAttemptRow"
      }
    },
    "non_disambiguating_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "why_further_inference_is_not_possible": {
      "type": "string",
      "minLength": 1
    },
    "span_alignment": {
      "$ref": "#/definitions/graphAlignmentRowsPayload"
    },
    "artifact_promotion": {
      "type": "object"
    }
  },
  "additionalProperties": true,
  "oneOf": [
    {
      "$ref": "#/definitions/partialReview"
    },
    {
      "$ref": "#/definitions/passedReview"
    }
  ],
  "definitions": {
    "rowsPayload": {
      "type": "object",
      "required": ["status", "row_count", "rows"],
      "properties": {
        "status": {
          "type": "string",
          "minLength": 1
        },
        "row_count": {
          "type": "integer",
          "minimum": 0
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": true
    },
    "graphAlignmentRow": {
      "type": "object",
      "required": [
        "span_id",
        "graph_operator_span_id",
        "location_kind",
        "operator_evidence_kind",
        "requires_further_drilldown"
      ],
      "properties": {
        "span_id": {
          "type": "string",
          "minLength": 1
        },
        "graph_operator_span_id": {
          "type": "string",
          "minLength": 1
        },
        "location_kind": {
          "type": "string",
          "enum": [
            "operator_call",
            "module_call_anchor",
            "graph_replay_entry",
            "constructor_line"
          ]
        },
        "operator_evidence_kind": {
          "type": "string",
          "enum": [
            "torch_call",
            "torch_functional_call",
            "torch_npu_call",
            "npu_custom_op",
            "triton_call",
            "tensor_expression",
            "collective_call",
            "device_cache_op"
          ]
        },
        "requires_further_drilldown": {
          "type": "boolean"
        },
        "code_location": {
          "type": "string",
          "pattern": "^[^:]+:\\d+$"
        },
        "code_location_human": {
          "type": "string"
        },
        "path_explanation": {
          "type": "string"
        },
        "template_key": {
          "type": "string",
          "minLength": 1
        },
        "selected_source_line_text": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "finalGraphAlignmentRow": {
      "allOf": [
        {
          "$ref": "#/definitions/graphAlignmentRow"
        },
        {
          "required": [
            "code_location",
            "template_key",
            "selected_source_line_text"
          ],
          "properties": {
            "location_kind": {
              "const": "operator_call"
            },
            "requires_further_drilldown": {
              "const": false
            }
          }
        }
      ]
    },
    "decisionTemplateCandidate": {
      "type": "object",
      "required": ["code_location"],
      "properties": {
        "code_location": {
          "type": "string",
          "pattern": "^[^:]+:\\d+$"
        },
        "kind": {
          "type": "string"
        },
        "why_possible": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "rejectedCandidate": {
      "type": "object",
      "required": ["code_location", "rejection_reason"],
      "properties": {
        "code_location": {
          "type": "string",
          "pattern": "^[^:]+:\\d+$"
        },
        "rejection_reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "decisionTemplate": {
      "type": "object",
      "required": ["template_key"],
      "properties": {
        "template_key": {
          "type": "string",
          "minLength": 1
        },
        "phase_basis": {
          "type": "string"
        },
        "model_role_basis": {
          "type": "string"
        },
        "backend_basis": {
          "type": "string"
        },
        "branch_basis": {
          "type": "string"
        },
        "candidate_code_locations": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/decisionTemplateCandidate"
          }
        },
        "selected_code_location": {
          "type": "string",
          "pattern": "^[^:]+:\\d+$"
        },
        "selected_source_line_text": {
          "type": "string"
        },
        "rejected_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/rejectedCandidate"
          }
        },
        "why_selected": {
          "type": "string"
        },
        "affected_span_count": {
          "type": "integer",
          "minimum": 0
        },
        "example_span_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "templateSummaryRow": {
      "type": "object",
      "required": ["template_key", "affected_span_count"],
      "properties": {
        "template_key": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "type": "string"
        },
        "semantic_class": {
          "type": "string"
        },
        "affected_span_count": {
          "type": "integer",
          "minimum": 0
        },
        "example_span_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stuck_at": {
          "type": "string"
        },
        "why_not_freezable": {
          "type": "string"
        },
        "remaining_candidate_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requires_repo_read_more": {
          "type": "boolean"
        },
        "requires_runtime_confirmation": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "remainingCandidateSummaryRow": {
      "type": "object",
      "required": [
        "template_key",
        "affected_span_count",
        "candidate_code_locations",
        "why_candidates_remain_tied"
      ],
      "properties": {
        "template_key": {
          "type": "string",
          "minLength": 1
        },
        "affected_span_count": {
          "type": "integer",
          "minimum": 1
        },
        "candidate_code_locations": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/definitions/decisionTemplateCandidate"
          }
        },
        "why_candidates_remain_tied": {
          "type": "string",
          "minLength": 1
        },
        "example_span_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "eliminationAttemptRow": {
      "type": "object",
      "required": ["dimension", "attempted_on_templates", "outcome"],
      "properties": {
        "dimension": {
          "type": "string",
          "minLength": 1
        },
        "attempted_on_templates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "outcome": {
          "type": "string",
          "minLength": 1
        },
        "eliminated_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/rejectedCandidate"
          }
        }
      },
      "additionalProperties": true
    },
    "graphAlignmentRowsPayload": {
      "allOf": [
        {
          "$ref": "#/definitions/rowsPayload"
        },
        {
          "properties": {
            "rows": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/graphAlignmentRow"
              }
            }
          }
        }
      ]
    },
    "repoFileEvidenceCheck": {
      "type": "object",
      "required": [
        "checked_against_repo_divergence_report",
        "existing_files_relied_on",
        "missing_files_relied_on",
        "contradictions"
      ],
      "properties": {
        "checked_against_repo_divergence_report": {
          "type": "boolean"
        },
        "existing_files_relied_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_files_relied_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "contradictions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "artifactPromotion": {
      "type": "object",
      "properties": {
        "graph_execution_plan_updates": {
          "type": "object"
        },
        "graph_forward_context_updates": {
          "type": "object"
        },
        "graph_span_candidates_payload": {
          "$ref": "#/definitions/rowsPayload"
        },
        "forward_segment_template_payload": {
          "$ref": "#/definitions/rowsPayload"
        },
        "graph_span_alignment_payload": {
          "$ref": "#/definitions/graphAlignmentRowsPayload"
        }
      },
      "additionalProperties": true
    },
    "partialReview": {
      "type": "object",
      "properties": {
        "status": {
          "const": "partial"
        },
        "review_outcome": {
          "const": "blocked"
        },
        "unresolved_template_summary": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/templateSummaryRow"
          }
        },
        "blocking_issues": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "remaining_candidates_summary": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/remainingCandidateSummaryRow"
          }
        },
        "elimination_attempts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/eliminationAttemptRow"
          }
        },
        "non_disambiguating_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "why_further_inference_is_not_possible": {
          "type": "string",
          "minLength": 1
        },
        "artifact_promotion": {
          "allOf": [
            {
              "$ref": "#/definitions/artifactPromotion"
            },
            {
              "required": [
                "graph_execution_plan_updates",
                "graph_forward_context_updates",
                "graph_span_candidates_payload",
                "forward_segment_template_payload"
              ],
              "properties": {
                "graph_execution_plan_updates": {
                  "type": "object",
                  "required": ["status"],
                  "properties": {
                    "status": {
                      "const": "partial"
                    }
                  }
                },
                "graph_forward_context_updates": {
                  "type": "object",
                  "required": ["status"],
                  "properties": {
                    "status": {
                      "const": "partial"
                    }
                  }
                }
              }
            }
          ]
        }
      },
      "required": [
        "unresolved_template_summary",
        "blocking_issues",
        "remaining_candidates_summary",
        "elimination_attempts",
        "non_disambiguating_evidence",
        "why_further_inference_is_not_possible"
      ]
    },
    "passedReview": {
      "type": "object",
      "properties": {
        "status": {
          "const": "passed"
        },
        "review_outcome": {
          "const": "approved"
        },
        "blocking_issues": {
          "type": "array",
          "maxItems": 0
        },
        "decision_templates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/decisionTemplate"
          }
        },
        "span_alignment": {
          "allOf": [
            {
              "$ref": "#/definitions/graphAlignmentRowsPayload"
            },
            {
              "properties": {
                "rows": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/finalGraphAlignmentRow"
                  }
                }
              }
            }
          ]
        },
        "artifact_promotion": {
          "allOf": [
            {
              "$ref": "#/definitions/artifactPromotion"
            },
            {
              "required": [
                "graph_execution_plan_updates",
                "graph_forward_context_updates",
                "graph_span_candidates_payload",
                "forward_segment_template_payload",
                "graph_span_alignment_payload"
              ],
              "properties": {
                "graph_execution_plan_updates": {
                  "type": "object",
                  "required": ["status"],
                  "properties": {
                    "status": {
                      "const": "passed"
                    }
                  }
                },
                "graph_forward_context_updates": {
                  "type": "object",
                  "required": ["status"],
                  "properties": {
                    "status": {
                      "const": "passed"
                    }
                  }
                },
                "graph_span_alignment_payload": {
                  "allOf": [
                    {
                      "$ref": "#/definitions/graphAlignmentRowsPayload"
                    },
                    {
                      "properties": {
                        "rows": {
                          "type": "array",
                          "items": {
                            "$ref": "#/definitions/finalGraphAlignmentRow"
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          ]
        }
      },
      "required": ["decision_templates"]
    }
  }
}
